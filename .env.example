# Backend mode: hosted (default) | private
# hosted = Personize Cloud (full surface). private = self-hosted Personize Private
# gateway (auto-selected when PERSONIZE_GATEWAY_URL is set). See docs/PERSONIZE-PRIVATE.md.
PERSONIZE_MODE=hosted

# Personize Cloud (hosted mode)
PERSONIZE_SECRET_KEY=sk_live_your_key_here
PERSONIZE_API_BASE_URL=https://agent.personize.ai
PERSONIZE_CRM_CONNECTION_ID=

# Personize Private gateway (private mode) — the bearer to reach YOUR gateway
PERSONIZE_GATEWAY_URL=
PERSONIZE_GATEWAY_KEY=

# Engine safety — dry-run is ON by default; set to false only in production
DRY_RUN=true
LOG_LEVEL=info

# MCP profile: planner (default) | operator | admin | auditor
MCP_PROFILE=planner

# Web-search MCP keys (hosted mode). Set ONE to give research subagents a search
# tool — `npm run setup` registers + credentials it on Personize, and
# `npm run setup:verify` probes the connection. Leave both unset to rely on the
# native webSearch fallback (see AGENTS.md / OPERATOR_WEBSEARCH_DEFAULT).
#   Tavily:      https://app.tavily.com  → set TAVILY_API_KEY
#   Parallel.ai: https://platform.parallel.ai (free anon; key raises limits)
TAVILY_API_KEY=
PARALLEL_API_KEY=
# Override only if the Personize team confirms a different MCP REST route:
# PERSONIZE_MCP_API_PATH=/api/v1/mcps

# Engine webhook server
# Managed hosts usually inject PORT; local runs can use ENGINE_PORT.
ENGINE_PORT=3000
PERSONIZE_WEBHOOK_SECRET=whsec_your_secret_here
PERSONIZE_WEBHOOK_URL=https://your-deployed-engine.example.com/webhook
# Dev only: set to 1 to accept unsigned webhooks when PERSONIZE_WEBHOOK_SECRET is unset.
# Never set this in production.
# ALLOW_UNSIGNED_WEBHOOKS=1
