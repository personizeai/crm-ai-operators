PERSONIZE_SECRET_KEY=sk_live_your_key_here

# Safe by default. Live CRM writes require DRY_RUN=false.
DRY_RUN=true
LOG_LEVEL=info

# Optional: Personize API base URL. Override only for staging environments.
PERSONIZE_API_BASE_URL=https://api.personize.ai

# Optional: pin a specific Personize CRM connection. Most callers can omit;
# Personize uses the org's default connection per CRM.
PERSONIZE_CRM_CONNECTION_ID=

# Optional MCP server profile: planner | operator | admin | auditor
# Controls what operations the MCP-connected agent is allowed to run.
MCP_PROFILE=planner
