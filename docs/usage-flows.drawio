    <diagram name="2 · Recurring Autonomous Loop" id="flow2">
        <mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1000" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title2" value="Flow 2 — Recurring Autonomous Loop&#xa;How AI agents operate the CRM on a schedule, unattended" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
                    <mxGeometry x="40" y="20" width="900" height="46" as="geometry"/>
                </mxCell>
                <!-- Trigger -->
                <mxCell id="trigger" value="&lt;b&gt;Trigger&lt;/b&gt;&lt;br&gt;cron · Claude Code routine · Personize schedule&lt;br&gt;(e.g. weekdays 7AM, hourly, 30 min pre-call, Mondays)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
                    <mxGeometry x="560" y="90" width="360" height="70" as="geometry"/>
                </mxCell>
                <!-- Loop phases -->
                <mxCell id="p1" value="&lt;b&gt;1 · STRATEGIZE&lt;/b&gt;&lt;br&gt;Recall what&#39;s known + what changed,&lt;br&gt;decide what&#39;s worth doing&lt;br&gt;&lt;i&gt;optimize.review-runs · optimize.refine-icp&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
                    <mxGeometry x="560" y="240" width="360" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="p2" value="&lt;b&gt;2 · RUN OPERATIONS&lt;/b&gt;&lt;br&gt;Score · research · generate · sync · analyze&lt;br&gt;&lt;i&gt;prompt (deterministic) or subagent (autonomous)&lt;/i&gt;&lt;br&gt;governed by guidelines, grounded in memory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
                    <mxGeometry x="1060" y="430" width="360" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="p3" value="&lt;b&gt;3 · REVIEW&lt;/b&gt;&lt;br&gt;Check outcomes &amp; gaps&lt;br&gt;&lt;i&gt;report.pipeline-health · report.win-loss&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
                    <mxGeometry x="560" y="640" width="360" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="p4" value="&lt;b&gt;4 · MONITOR &amp; ESCALATE&lt;/b&gt;&lt;br&gt;Surface only what needs a human&lt;br&gt;&lt;i&gt;act.daily-digest · act.notify-rep-handoff&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
                    <mxGeometry x="60" y="430" width="360" height="120" as="geometry"/>
                </mxCell>
                <!-- Center -->
                <mxCell id="center" value="&lt;b&gt;Personize&lt;/b&gt;&lt;br&gt;Memory · Governance · Audit&lt;br&gt;&lt;br&gt;every step is grounded in memory,&lt;br&gt;gated by guidelines, and logged" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=0;" vertex="1" parent="1">
                    <mxGeometry x="600" y="410" width="280" height="160" as="geometry"/>
                </mxCell>
                <!-- Side systems -->
                <mxCell id="crm" value="&lt;b&gt;CRM (HubSpot / Salesforce)&lt;/b&gt;&lt;br&gt;personize_* writeback — every read &amp; write audited" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
                    <mxGeometry x="1080" y="640" width="320" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="human" value="&lt;b&gt;Human (RevOps / AE / Leadership)&lt;/b&gt;&lt;br&gt;receives digests &amp; handoffs (Slack / email)&lt;br&gt;adjusts the playbook" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
                    <mxGeometry x="60" y="640" width="320" height="80" as="geometry"/>
                </mxCell>
                <!-- Edges: trigger then clockwise loop -->
                <mxCell id="te" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="trigger" target="p1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="le1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#444444;endArrow=block;strokeWidth=2;exitX=1;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="p1" target="p2">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="le2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#444444;endArrow=block;strokeWidth=2;exitX=0.5;exitY=1;entryX=1;entryY=0.5;" edge="1" parent="1" source="p2" target="p3">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="le3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#444444;endArrow=block;strokeWidth=2;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="p3" target="p4">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="le4" value="repeat" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#444444;endArrow=block;strokeWidth=2;exitX=0.5;exitY=0;entryX=0;entryY=0.5;fontSize=11;fontStyle=1;" edge="1" parent="1" source="p4" target="p1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- Writeback + escalation -->
                <mxCell id="wb" value="writeback&#xa;personize_* fields" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;endArrow=block;dashed=1;fontSize=10;" edge="1" parent="1" source="p2" target="crm">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="esc" value="notify / hand off" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d79b00;endArrow=block;dashed=1;fontSize=10;" edge="1" parent="1" source="p4" target="human">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="adj" value="refine playbook / guidelines" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d79b00;endArrow=block;dashed=1;fontSize=10;exitX=0.5;exitY=0;entryX=0.1;entryY=1;" edge="1" parent="1" source="human" target="p4">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- Grounding links to center -->
                <mxCell id="g1" style="html=1;strokeColor=#82b366;endArrow=none;dashed=1;dashPattern=1 3;" edge="1" parent="1" source="p1" target="center">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="g2" style="html=1;strokeColor=#82b366;endArrow=none;dashed=1;dashPattern=1 3;" edge="1" parent="1" source="p2" target="center">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="g3" style="html=1;strokeColor=#82b366;endArrow=none;dashed=1;dashPattern=1 3;" edge="1" parent="1" source="p3" target="center">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="g4" style="html=1;strokeColor=#82b366;endArrow=none;dashed=1;dashPattern=1 3;" edge="1" parent="1" source="p4" target="center">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="note2" value="Set the playbook once; the CRM runs itself — and tells you what it did. Agents stay silent unless something crosses a threshold worth a human&#39;s attention." style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#666666;whiteSpace=wrap;" vertex="1" parent="1">
                    <mxGeometry x="60" y="780" width="1340" height="30" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
